# "production" locks the app down for a real internet-facing deployment:
# closes /docs, /redoc, /openapi.json, and refuses to start at all if
# SECRET_KEY below is still a placeholder or under 32 characters.
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://workpilot:workpilot@localhost:5432/workpilot
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-generate-a-random-value
CORS_ORIGINS=["http://localhost:5173"]

# Optional -- leave unset to run with no error-monitoring service at all.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional -- leave unset to keep returning the OTP code directly in the
# API response (local dev/testing only). Set both to actually send codes
# via SMS through Kavenegar (https://panel.kavenegar.com -> API Key page).
# KAVENEGAR_OTP_TEMPLATE must match a template already approved in that
# panel (Settings -> Verify Templates) -- Kavenegar's Verify/Lookup API
# only sends pre-approved templates, not free-form text.
# KAVENEGAR_API_KEY=your-kavenegar-api-key
# KAVENEGAR_OTP_TEMPLATE=verify
